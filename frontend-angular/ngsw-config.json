{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/Expense-Tracking/app/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/Expense-Tracking/app/favicon.ico",
          "/Expense-Tracking/app/index.html",
          "/Expense-Tracking/app/manifest.webmanifest",
          "/Expense-Tracking/app/*.css",
          "/Expense-Tracking/app/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/Expense-Tracking/app/assets/**",
          "/Expense-Tracking/app/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-auth",
      "urls": ["/Expense-Tracking/api/auth/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 5,
        "maxAge": "0u"
      }
    },
    {
      "name": "api-data",
      "urls": ["/Expense-Tracking/api/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ]
}
